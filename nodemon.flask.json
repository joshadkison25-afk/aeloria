{
  "watch": ["."],
  "ext": "py",
  "ignore": [
    "node_modules/**",
    ".next/**",
    "venv/**",
    "logs/**",
    "**/__pycache__/**",
    "tests/**",
    "public/**",
    "history/**",
    "conversations/**",
    "*.json",
    "*.md"
  ],
  "exec": "cross-env FLASK_DEBUG=1 FLASK_SKIP_RELOADER=1 python app.py",
  "delay": 500
}
