{
  "watch": [
    "app",
    "components",
    "lib",
    "data",
    "public",
    "next.config.js",
    "tailwind.config.js",
    "postcss.config.js"
  ],
  "ext": "ts,tsx,js,jsx,mjs,cjs,json,css,scss,md,mdx",
  "ignore": [".next/**", "node_modules/**"],
  "exec": "next dev -p 3000",
  "delay": 1200
}
