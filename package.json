{
  "name": "aeloria",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n next,flask -c cyan,magenta \"npm run dev:next\" \"npm run dev:flask\"",
    "dev:next": "next dev -p 3000",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3000",
    "dev:next:reload": "nodemon --config nodemon.next.json",
    "dev:flask": "nodemon --config nodemon.flask.json",
    "dev:all:fast": "npm run dev",
    "dev:all": "concurrently -k -n next,flask -c cyan,magenta \"npm run dev:next:reload\" \"npm run dev:flask\"",
    "vibe": "npm run dev",
    "dev:vibe": "npm run dev",
    "map:from-azgaar": "node scripts/azgaar-map-to-aeloria-regions.mjs",
    "generate:lore-houses-map": "node scripts/generate-lore-house-map.mjs",
    "generate:atlas-basemap": "node scripts/generate-lore-house-map.mjs",
    "build:strategy-map-data": "node scripts/build-strategy-map-data.mjs",
    "build:territory-map": "node scripts/build-house-territories.mjs",
    "build:terrain-map": "node scripts/build-terrain-map.mjs",
    "build:map-geo": "node scripts/build-map-geo.mjs",
    "build:map-geojson": "node scripts/build-map-geojson.mjs",
    "paint:map-core": "node scripts/paint-map-core-from-layout.mjs",
    "image:enter": "python scripts/generate_enter_background.py",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.24.0",
    "next": "14.0.0",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "d3-delaunay": "^6.0.4",
    "polygon-clipping": "^0.15.3",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.0.0",
    "nodemon": "^3.1.14",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
