ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
# Optional: size for scripts/generate_enter_background.py (defaults to OPENAI_IMAGE_SIZE or 1536x1024)
# OPENAI_ENTER_IMAGE_SIZE=1536x1024
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
DISCORD_WEBHOOK_URL=

LORE_DOCS_PATH=C:\Users\Josh\Desktop\lore_docs
# Optional: map editor saves try this folder first, then LORE_DOCS_PATH/maps, then <repo>/lore/maps
# AELORIA_MAPS_SAVE_DIR=
STYLE_GUIDE_NAME=eryndor adventure

TICK_INTERVAL_HOURS=8
API_MODEL=claude-sonnet-4-6
PORT=5000
# 1 = restart Flask on Python file changes; use 0 in production
FLASK_DEBUG=1
# Local dev: full URL to Next `/map` (Flask + Next on two ports). Docker/nginx reverse-proxy prod often uses path-only `/map`.
MAP_PUBLIC_URL=http://127.0.0.1:3000/map
NEXT_PUBLIC_SITE_URL=https://your-domain.example
# Optional: atlas under public/ — used by Next `/map` and Flask home hero (same default if unset)
# NEXT_PUBLIC_MAP_ATLAS_URL=/your-export.png
# HOME_ATLAS_URL=/your-export.png
# Home hero: embed Next map in iframe (needs Next dev/prod on MAP_PUBLIC_URL). Set 0 for static image only.
# HOME_INTERACTIVE_MAP=1
# 1 = use polygons from data/regions.azgaar-generated.ts (`npm run map:from-azgaar` uses Tidy Full 2026-04-26-20-50.json when present)
# NEXT_PUBLIC_USE_AZGAAR_REGIONS=1
# 1 = one province per named house/clan + flat unlabeled SVG basemap (`npm run generate:lore-houses-map`)
# NEXT_PUBLIC_USE_LORE_HOUSE_MAP=1
